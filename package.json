{
  "name": "@chirag127/oriz-book-build",
  "version": "0.1.0",
  "description": "Pandoc-wrapping CLI for the chirag127/oriz family. Builds EPUB3 / PDF / MOBI / Markua from a manuscript/ dir of Markua-flavoured .md files + book.json metadata. Used by oriz-*-book repos and exposed via `oriz-book` bin.",
  "type": "module",
  "license": "MIT",
  "author": "Chirag Singhal <chirag@oriz.in>",
  "homepage": "https://github.com/chirag127/oriz-book-build-npm-pkg#readme",
  "repository": { "type": "git", "url": "git+https://github.com/chirag127/oriz-book-build-npm-pkg.git" },
  "bugs": { "url": "https://github.com/chirag127/oriz-book-build-npm-pkg/issues" },
  "keywords": ["chirag127", "oriz", "book", "pandoc", "epub", "markua", "pdf", "mobi", "leanpub", "kdp"],
  "files": ["src", "LICENSE", "README.md"],
  "main": "./src/index.ts",
  "types": "./src/index.ts",
  "bin": { "oriz-book": "./src/cli.ts" },
  "exports": { ".": "./src/index.ts" },
  "publishConfig": { "access": "public" },
  "scripts": {
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage"
  },
  "devDependencies": {
    "vitest": "^2.0.0",
    "@vitest/coverage-v8": "^2.0.0",
    "happy-dom": "^20.10.6",
    "typescript": "^5.6.0"
  }
}
